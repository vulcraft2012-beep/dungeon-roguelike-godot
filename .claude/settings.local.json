{
  "permissions": {
    "allow": [
      "Bash(where gh:*)",
      "Bash(winget install:*)",
      "Bash(powershell.exe -Command \"winget install --id GitHub.cli -e --accept-source-agreements --accept-package-agreements\")",
      "Bash(powershell.exe -Command \"Invoke-WebRequest -Uri ''https://github.com/cli/cli/releases/download/v2.67.0/gh_2.67.0_windows_amd64.zip'' -OutFile ''C:/Users/Вулкрафт/gh.zip''\")",
      "Bash(powershell.exe -Command \"Expand-Archive -Path ''C:/Users/Вулкрафт/gh.zip'' -DestinationPath ''C:/Users/Вулкрафт/gh_cli'' -Force\")",
      "Bash(export PATH=\"/c/Users/Вулкрафт/gh_cli/bin:$PATH\")",
      "Bash(gh --version)",
      "Bash(gh auth:*)"
    ]
  }
}
